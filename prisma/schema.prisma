generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  email          String?   @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  walletAddress  String?   @unique
  airdropClaimed Boolean   @default(false)
  airdropTxSig   String?
  accounts       Account[]
  sessions       Session[]
  cards          Card[]
}

model Card {
  id            String     @id @default(cuid())
  slug          String     @unique @default(cuid())
  creatorId     String
  creator       User       @relation(fields: [creatorId], references: [id])
  tier          Int
  burnAmountAnn Int
  recipientName String?
  message       String     @db.Text
  background    String
  emojis        String?
  photoUrl      String?
  musicTrack    String?
  memoText      String?
  mode          CardMode   @default(CRYPTO)
  burnTxSig     String?    @unique   // null for FREE mode cards
  status        CardStatus @default(PUBLISHED)
  openedAt      DateTime?
  createdAt     DateTime   @default(now())
}

enum CardStatus {
  PUBLISHED
  OPENED
}

enum CardMode {
  FREE
  CRYPTO
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
